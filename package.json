{
  "name": "paperclip",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/adapters/*",
    "server",
    "ui",
    "cli",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev-runner.mjs dev",
    "dev:watch": "PAPERCLIP_MIGRATION_PROMPT=never bun scripts/dev-runner.mjs watch",
    "dev:server": "bun run --filter @paperclipai/server dev",
    "dev:ui": "bun run --filter @paperclipai/ui dev",
    "dev:control-plane": "bun run --filter @paperclipai/control-plane dev",
    "build": "bun run --workspaces --if-present --sequential build",
    "typecheck": "bun run --workspaces --if-present --sequential typecheck",
    "test": "vitest",
    "test:run": "vitest run && bun run --filter @paperclipai/control-plane test:run",
    "db:generate": "bun run --filter @paperclipai/db generate",
    "db:migrate": "bun run --filter @paperclipai/db migrate",
    "secrets:migrate-inline-env": "tsx scripts/migrate-inline-env-secrets.ts",
    "db:backup": "./scripts/backup-db.sh",
    "paperclipai": "bun run --filter paperclipai dev",
    "build:npm": "./scripts/build-npm.sh",
    "release": "./scripts/release.sh",
    "changeset": "bun x changeset",
    "version-packages": "bun x changeset version",
    "deploy:control-plane": "bun run --filter @paperclipai/control-plane deploy",
    "check:tokens": "node scripts/check-forbidden-tokens.mjs",
    "docs:dev": "bun x mintlify dev",
    "smoke:openclaw-join": "./scripts/smoke/openclaw-join.sh",
    "smoke:openclaw-docker-ui": "./scripts/smoke/openclaw-docker-ui.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.10"
}
